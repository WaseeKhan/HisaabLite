<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>Billing - HisaabLite</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <meta name="_csrf" th:content="${_csrf.token}" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            display: flex;
            height: 100vh;
            background: #f3f4f6;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 260px;
            background: #0f172a;
            color: white;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.05);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
            padding: 0 8px;
        }

        .logo img {
            width: 36px;
            height: 36px;
            filter: brightness(0) invert(1);
        }

        .logo h3 {
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .nav-links {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
        }

        .nav-links a {
            padding: 12px 16px;
            border-radius: 10px;
            margin: 2px 0;
            text-decoration: none;
            color: #cbd5e1;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-links a i {
            width: 20px;
            font-size: 16px;
        }

        .nav-links a:hover {
            background: #1e293b;
            color: white;
        }

        .nav-links a.active {
            background: #2563eb;
            color: white;
            box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3);
        }

        .logout-btn {
            width: 100%;
            padding: 12px 16px;
            background: #dc2626;
            border: none;
            color: white;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.2s;
            margin-top: 20px;
        }

        .logout-btn:hover {
            background: #b91c1c;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
        }

        /* ===== MAIN ===== */
        .main {
            flex: 1;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
        }

        /* ===== TOPBAR ===== */
        .topbar {
            background: white;
            padding: 16px 24px;
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            border: 1px solid #edf2f7;
        }

        .shop-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .shop-name {
            font-weight: 700;
            font-size: 16px;
            color: #0f172a;
        }

        .badge {
            background: #e6f0ff;
            color: #2563eb;
            padding: 4px 10px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            color: #4b5563;
            font-size: 14px;
        }

        .role-badge {
            background: #f3f4f6;
            padding: 6px 14px;
            border-radius: 30px;
            font-weight: 600;
            color: #0f172a;
        }

        /* ===== BILLING LAYOUT ===== */
        .billing-layout {
            flex: 1;
            display: grid;
            grid-template-columns: 1.2fr 1.8fr;
            gap: 20px;
            min-height: 0;
        }

        /* ===== LEFT PANEL ===== */
        .left-panel {
            background: white;
            padding: 24px;
            border-radius: 20px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.03);
            border: 1px solid #edf2f7;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title i {
            color: #2563eb;
            font-size: 18px;
        }

        .search-container {
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 14px;
            top: 14px;
            color: #9ca3af;
            font-size: 14px;
        }

        #searchInput {
            width: 100%;
            padding: 14px 16px 14px 42px;
            border: 1.5px solid #e5e7eb;
            border-radius: 14px;
            font-size: 14px;
            transition: all 0.2s;
            background: #f9fafb;
        }

        #searchInput:focus {
            border-color: #2563eb;
            outline: none;
            background: white;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

        #searchResults {
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            max-height: 220px;
            overflow-y: auto;
            margin-top: 8px;
            background: white;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        }

        .suggestion-item {
            padding: 12px 16px;
            cursor: pointer;
            border-bottom: 1px solid #f3f4f6;
            font-size: 14px;
            transition: all 0.1s;
        }

        .suggestion-item:last-child {
            border-bottom: none;
        }

        .suggestion-item.active,
        .suggestion-item:hover {
            background: #2563eb;
            color: white;
        }

        .suggestion-item.active .stock {
            color: #cbd5e1;
        }

        .qty-add-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 8px 0 16px;
        }

        .qty-input {
            background: #f9fafb;
            border: 1.5px solid #e5e7eb;
            border-radius: 14px;
            padding: 14px;
            font-size: 14px;
            font-weight: 600;
        }

        .add-btn {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            border: none;
            border-radius: 14px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px;
            box-shadow: 0 8px 16px rgba(15, 23, 42, 0.15);
        }

        .add-btn:hover {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            transform: translateY(-2px);
            box-shadow: 0 12px 20px rgba(15, 23, 42, 0.2);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 8px;
        }

        .form-group {
            margin-bottom: 8px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 600;
            color: #4b5563;
            margin-bottom: 6px;
            display: block;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
            background: #f9fafb;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: #2563eb;
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .discount-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .change-return {
            background: #f0fdf4;
            padding: 14px;
            border-radius: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            border: 1px solid #bbf7d0;
            margin: 12px 0;
        }

        .change-return span:last-child {
            color: #16a34a;
            font-size: 18px;
        }

        .complete-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #059669, #10b981);
            color: white;
            border: none;
            border-radius: 16px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 10px 20px rgba(5, 150, 105, 0.2);
            margin-top: 8px;
        }

        .complete-btn:hover {
            background: linear-gradient(135deg, #047857, #059669);
            transform: translateY(-2px);
            box-shadow: 0 15px 25px rgba(5, 150, 105, 0.3);
        }

        /* ===== RIGHT PANEL ===== */
        .right-panel {
            background: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.03);
            border: 1px solid #edf2f7;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding: 0 8px;
        }

        .cart-header h3 {
            font-size: 18px;
            font-weight: 700;
            color: #0f172a;
        }

        .cart-count {
            background: #2563eb;
            color: white;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
        }

        .cart-table-container {
            flex: 1;
            overflow-y: auto;
            border-radius: 16px;
            background: #f8fafc;
            padding: 4px;
        }

        #cartTable {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        #cartTable thead {
            background: #f1f5f9;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        #cartTable th {
            padding: 14px 12px;
            text-align: left;
            font-weight: 600;
            color: #334155;
            font-size: 13px;
        }

        #cartTable tbody tr {
            transition: 0.2s ease;
            border-bottom: 1px solid #e2e8f0;
        }

        #cartTable tbody tr:hover {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        }

        #cartTable td {
            padding: 14px 12px;
            color: #1e293b;
        }

        .qty-control {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .qty-btn {
            width: 28px;
            height: 28px;
            border: none;
            background: #e2e8f0;
            color: #1e293b;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .qty-btn:hover {
            background: #2563eb;
            color: white;
        }

        .qty-value {
            font-weight: 600;
            min-width: 30px;
            text-align: center;
        }

        /* ===== TOTAL BOX ===== */
        .total-box {
            margin-top: 16px;
            padding: 20px;
            border-radius: 18px;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .total-row.discount {
            color: #fcd34d;
        }

        .total-row.final {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 2px dashed rgba(255, 255, 255, 0.2);
            font-size: 18px;
            font-weight: 700;
        }

        .final-amount {
            font-size: 24px;
            font-weight: 800;
            color: #fbbf24;
        }

        /* ===== TOAST ===== */
        .toast {
            visibility: hidden;
            min-width: 340px;
            background: #0f172a;
            color: white;
            border-radius: 16px;
            padding: 20px;
            position: fixed;
            z-index: 9999;
            right: 30px;
            bottom: 30px;
            font-size: 15px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            opacity: 0;
            transition: all 0.3s;
            border-left: 5px solid #fbbf24;
        }

        .toast.show {
            visibility: visible;
            opacity: 1;
            bottom: 40px;
        }

        .toast-content {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .toast-icon {
            background: #10b981;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .invoice-btn {
            background: #fbbf24;
            color: #0f172a;
            padding: 10px 18px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            display: inline-block;
            transition: all 0.2s;
        }

        .invoice-btn:hover {
            background: #f59e0b;
            transform: translateY(-2px);
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="https://cdn-icons-png.flaticon.com/512/891/891419.png">
            <h3>HisaabLite</h3>
        </div>

        <div class="nav-links">
            <a th:href="@{/dashboard}"><i class="fas fa-chart-pie"></i> Dashboard</a>
            <a class="active" th:if="${role == 'OWNER' or role == 'CASHIER'}" th:href="@{/sales/new}">
                <i class="fas fa-cash-register"></i> Billings
            </a>
            <a th:if="${role == 'OWNER' or role == 'MANAGER'}" th:href="@{/products}">
                <i class="fas fa-box"></i> Products
            </a>
            <a th:href="@{/sales/history}">
                <i class="fas fa-history"></i> Sales History
            </a>
            <a th:if="${role == 'OWNER'}" th:href="@{/staff}">
                <i class="fas fa-users"></i> Staff
            </a>
            <a th:if="${role == 'OWNER'}" th:href="@{/profile}">
                <i class="fas fa-store"></i> Profile
            </a>
        </div>

        <form th:action="@{/logout}" method="post">
            <button type="submit" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">
        <!-- TOPBAR -->
        <div class="topbar">
            <div class="shop-info">
                <span class="shop-name" th:text="${shop.name}">Shop Name</span>
                <span class="badge">PAN: <span th:text="${shop.panNumber}"></span></span>
                <span class="badge">GST: <span th:text="${shop.gstNumber} ?: 'N/A'"></span></span>
            </div>

            <div class="user-info">
                <span class="role-badge"><i class="fas fa-user-circle"></i> <span th:text="${role}"></span></span>
                <span><i class="fas fa-store"></i> HL<span th:text="${shop.id}"></span></span>
                <span><i class="fas fa-crown"></i> <span th:text="${shop.subscriptionPlan}"></span></span>
            </div>
        </div>

        <!-- BILLING LAYOUT -->
        <div class="billing-layout">
            <!-- LEFT PANEL - Customer & Payment -->
            <div class="left-panel">
                <div>
                    <div class="section-title">
                        <i class="fas fa-search"></i> Search Product
                    </div>
                    <div class="search-container">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" id="searchInput" autocomplete="off" placeholder="Type product name..." />
                    </div>
                    <div id="searchResults"></div>

                    <div class="qty-add-row">
                        <input type="number" id="qtyInput" value="1" min="1" class="qty-input" />
                        <button id="addBtn" class="add-btn">
                            <i class="fas fa-plus-circle"></i> Add
                        </button>
                    </div>
                </div>

                <form th:action="@{/sales/complete}" method="post">
                    <div class="section-title">
                        <i class="fas fa-user"></i> Customer Details
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Customer's Name</label>
                            <input type="text" name="customerName" placeholder="Enter name" />
                        </div>
                        <div class="form-group">
                            <label>Customer's Phone</label>
                            <input type="text" name="customerPhone" placeholder="Enter phone" />
                        </div>
                    </div>

                    <div class="section-title" style="margin-top: 8px;">
                        <i class="fas fa-credit-card"></i> Payment Details
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Payment Mode</label>
                            <select name="paymentMode">
                                <option value="CASH">💰 Cash</option>
                                <option value="UPI">📱 UPI</option>
                                <option value="CARD">💳 Card</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Amount Received</label>
                            <input type="number" id="amountReceived" name="amountReceived" placeholder="0.00" min="0" />
                        </div>
                    </div>

                    <div class="section-title" style="margin-top: 8px;">
                        <i class="fas fa-tag"></i> Discount
                    </div>

                    <div class="discount-row">
                        <div class="form-group">
                            <label>₹ Discount</label>
                            <input type="number" id="discountAmount" name="discountAmount" placeholder="0" value="0" min="0" />
                        </div>
                        <div class="form-group">
                            <label>% Discount</label>
                            <input type="number" id="discountPercent" name="discountPercent" placeholder="0" value="0" min="0" max="100" />
                        </div>
                    </div>

                    <input type="hidden" id="changeReturned" name="changeReturned" />

                    <div class="change-return">
                        <span><i class="fas fa-exchange-alt"></i> Change Return</span>
                        <span>₹ <span id="changeAmount">0</span></span>
                    </div>

                    <button type="submit" class="complete-btn">
                        <i class="fas fa-check-circle"></i> Complete Billing
                    </button>
                </form>
            </div>

            <!-- RIGHT PANEL - Cart -->
            <div class="right-panel">
                <div class="cart-header">
                    <h3><i class="fas fa-shopping-cart" style="color: #2563eb;"></i> Current Cart</h3>
                    <span class="cart-count" th:text="${#lists.size(cart)} + ' items'">0 items</span>
                </div>

                <div class="cart-table-container">
                    <table id="cartTable">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th style="text-align: center;">Qty</th>
                                <th style="text-align: right;">Price</th>
                                <th style="text-align: right;">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr th:each="item : ${cart}">
                                <td th:text="${item.productName}"></td>
                                <td style="text-align: center;">
                                    <div class="qty-control">
                                        <button class="qty-btn" th:onclick="'changeQty(' + ${itemStat.index} + ', -1)'">-</button>
                                        <span class="qty-value" th:text="${item.quantity}"></span>
                                        <button class="qty-btn" th:onclick="'changeQty(' + ${itemStat.index} + ', 1)'">+</button>
                                    </div>
                                </td>
                                <td style="text-align: right;">₹<span th:text="${item.price}"></span></td>
                                <td style="text-align: right; font-weight: 600;">₹<span th:text="${item.subtotal}"></span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- TOTAL BOX -->
                <div class="total-box">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span>₹ <span id="subtotalAmount" th:text="${totalAmount}"></span></span>
                    </div>
                    <div class="total-row discount">
                        <span>Discount</span>
                        <span>- ₹ <span id="discountDisplay">0</span></span>
                    </div>
                    <div class="total-row final">
                        <span>Final Total</span>
                        <span class="final-amount">₹ <span id="finalTotalAmount" th:text="${totalAmount}"></span></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- TOAST NOTIFICATION -->
    <div id="successToast" class="toast">
        <div class="toast-content">
            <div class="toast-icon">✅</div>
            <div>
                <strong>Sale Completed!</strong><br>
                Redirecting to invoice...
            </div>
        </div>
        <a id="invoiceBtn" href="#" target="_blank" class="invoice-btn">View Invoice</a>
    </div>

    <!-- SAME JAVASCRIPT - BILKUL COPY KARO -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let suggestions = [];
            let selectedIndex = -1;
            let selectedProduct = null;

            const searchInput = document.getElementById("searchInput");
            const qtyInput = document.getElementById("qtyInput");
            const resultsBox = document.getElementById("searchResults");
            const cartBody = document.querySelector("#cartTable tbody");
            
            const amountReceivedInput = document.getElementById("amountReceived");
            const discountInput = document.getElementById("discountAmount");
            const discountPercentInput = document.getElementById("discountPercent");
            const changeAmountEl = document.getElementById("changeAmount");
            const subtotalEl = document.getElementById("subtotalAmount");
            const finalTotalEl = document.getElementById("finalTotalAmount");
            const discountDisplayEl = document.getElementById("discountDisplay");

            searchInput.focus();

            function calculateChange() {
                if (!subtotalEl || !finalTotalEl || !discountDisplayEl) return;
                
                const total = parseFloat(subtotalEl.innerText) || 0;
                const discountAmt = parseFloat(discountInput.value) || 0;
                const discountPercent = parseFloat(discountPercentInput.value) || 0;

                let finalDiscount = discountAmt;

                if (discountPercent > 0) {
                    finalDiscount = (total * discountPercent) / 100;
                }

                const finalTotal = total - finalDiscount;
                const received = parseFloat(amountReceivedInput.value) || 0;
                const change = received - finalTotal;

                const finalChange = change > 0 ? change.toFixed(2) : 0;

                if (changeAmountEl) changeAmountEl.innerText = finalChange;
                document.getElementById("changeReturned").value = finalChange;
                discountDisplayEl.innerText = finalDiscount.toFixed(2);
                finalTotalEl.innerText = finalTotal.toFixed(2);
            }

            if (amountReceivedInput) amountReceivedInput.addEventListener("input", calculateChange);
            if (discountInput) discountInput.addEventListener("input", calculateChange);
            if (discountPercentInput) discountPercentInput.addEventListener("input", calculateChange);

            searchInput.addEventListener("keydown", function (e) {
                const items = document.querySelectorAll(".suggestion-item");

                if (e.key === "ArrowDown") {
                    e.preventDefault();
                    if (items.length === 0) return;
                    selectedIndex++;
                    if (selectedIndex >= items.length) selectedIndex = 0;
                    updateHighlight(items);
                }

                if (e.key === "ArrowUp") {
                    e.preventDefault();
                    if (items.length === 0) return;
                    selectedIndex--;
                    if (selectedIndex < 0) selectedIndex = items.length - 1;
                    updateHighlight(items);
                }

                if (e.key === "Enter") {
                    e.preventDefault();
                    if (selectedIndex >= 0 && suggestions[selectedIndex]) {
                        selectedProduct = suggestions[selectedIndex];
                        searchInput.value = selectedProduct.name;
                        resultsBox.innerHTML = "";
                        qtyInput.focus();
                        qtyInput.select();
                    }
                }
            });

            searchInput.addEventListener("input", function () {
                const keyword = this.value.trim();

                if (keyword.length === 0) {
                    resultsBox.innerHTML = "";
                    selectedIndex = -1;
                    suggestions = [];
                    return;
                }

                fetch("/sales/search?keyword=" + keyword)
                    .then(res => {
                        if (!res.ok) throw new Error("Search failed");
                        return res.json();
                    })
                    .then(data => {
                        suggestions = data;
                        selectedIndex = -1;
                        resultsBox.innerHTML = "";

                        data.forEach((p, index) => {
                            const div = document.createElement("div");
                            div.classList.add("suggestion-item");
                            div.innerText = p.name + " - ₹" + p.price + " (Stock: " + p.stockQuantity + ")";
                            div.dataset.index = index;

                            div.addEventListener("click", function () {
                                selectedIndex = index;
                                selectedProduct = suggestions[index];
                                searchInput.value = selectedProduct.name;
                                resultsBox.innerHTML = "";
                                qtyInput.focus();
                                qtyInput.select();
                            });

                            resultsBox.appendChild(div);
                        });
                    });
            });

            qtyInput.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    addProduct();
                }
            });

            function addProduct() {
                if (!selectedProduct) {
                    alert("Select product first");
                    return;
                }

                const csrfToken = document.querySelector("meta[name='_csrf']").content;
                const qty = parseInt(qtyInput.value) || 1;

                fetch("/sales/add", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: "_csrf=" + csrfToken + "&productId=" + selectedProduct.id + "&quantity=" + qty
                })
                    .then(res => {
                        if (!res.ok) return res.text().then(text => { throw new Error(text); });
                        return res.json();
                    })
                    .then(cartData => {
                        updateCartUI(cartData);
                        searchInput.value = "";
                        qtyInput.value = 1;
                        selectedProduct = null;
                        selectedIndex = -1;
                        searchInput.focus();
                    })
                    .catch(err => alert(err.message));
            }

            function updateCartUI(cartData) {
                cartBody.innerHTML = "";
                let total = 0;

                cartData.forEach((item, index) => {
                    let subtotal = parseFloat(item.subtotal);
                    total += subtotal;

                    const row = `
                    <tr>
                        <td>${item.productName}</td>
                        <td style="text-align: center;">
                            <div class="qty-control">
                                <button class="qty-btn" onclick="changeQty(${index}, -1)">-</button>
                                <span class="qty-value">${item.quantity}</span>
                                <button class="qty-btn" onclick="changeQty(${index}, 1)">+</button>
                            </div>
                        </td>
                        <td style="text-align: right;">₹${item.price}</td>
                        <td style="text-align: right; font-weight: 600;">₹${subtotal.toFixed(2)}</td>
                    </tr>
                    `;
                    cartBody.insertAdjacentHTML("beforeend", row);
                });

                if (subtotalEl) subtotalEl.innerText = total.toFixed(2);
                if (finalTotalEl) finalTotalEl.innerText = total.toFixed(2);
                
                // Update cart count
                document.querySelector('.cart-count').innerText = cartData.length + ' items';
                
                calculateChange();
            }

            window.changeQty = function (index, change) {
                const csrfToken = document.querySelector("meta[name='_csrf']").content;

                fetch("/sales/update-qty", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: "_csrf=" + csrfToken + "&index=" + index + "&change=" + change
                })
                    .then(response => {
                        if (!response.ok) throw new Error("Server error");
                        return response.json();
                    })
                    .then(cartData => {
                        updateCartUI(cartData);
                    })
                    .catch(error => console.error("Error:", error));
            };

            function updateHighlight(items) {
                items.forEach(i => i.classList.remove("active"));
                if (items[selectedIndex]) {
                    items[selectedIndex].classList.add("active");
                    items[selectedIndex].scrollIntoView({ block: "nearest" });
                }
            }
        });

        window.onload = function () {
            const params = new URLSearchParams(window.location.search);
            if (params.get("saved") === "true") {
                const toast = document.getElementById("successToast");
                const invoiceId = params.get("invoiceId");
                document.getElementById("invoiceBtn").href = "/sales/invoice/" + invoiceId;
                toast.classList.add("show");
                setTimeout(() => toast.classList.remove("show"), 5000);
            }
        };
    </script>
</body>

</html>